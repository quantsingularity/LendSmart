# ─────────────────────────────────────────────────────────────────────────────
# LendSmart - Root Environment Configuration
# Copy this file to .env and fill in your values.
# Each sub-service (backend/, ml_services/) also has its own .env.example.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Node.js Backend ─────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
MONGODB_URI=mongodb://admin:password@localhost:27017/lendsmart?authSource=admin
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
JWT_SECRET=your-jwt-secret-minimum-32-characters-long
JWT_EXPIRE=1h
REFRESH_TOKEN_SECRET=your-refresh-token-secret-minimum-32-chars
REFRESH_TOKEN_EXPIRE=7d
ENCRYPTION_MASTER_KEY=your-encryption-master-key-32-chars!
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:8080
ADMIN_EMAIL=admin@lendsmart.com

# ─── AI / ML Service Endpoints ───────────────────────────────────────────────
AI_CREDIT_MODEL_ENDPOINT=http://localhost:8000/predict
AI_RISK_MODEL_ENDPOINT=http://localhost:8000/predict/risk
AI_FRAUD_MODEL_ENDPOINT=http://localhost:8000/predict/fraud
AI_SERVICE_TIMEOUT=30000
AI_RETRY_ATTEMPTS=3
AI_RETRY_DELAY=1000
CREDIT_SCORING_SERVICE_URL=http://localhost:8000

# ─── Blockchain ───────────────────────────────────────────────────────────────
BLOCKCHAIN_RPC_URL=http://localhost:8545
BLOCKCHAIN_CHAIN_ID=1337
LEND_SMART_LOAN_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID
POLYGON_RPC_URL=https://polygon-rpc.com
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID
ETHEREUM_PRIVATE_KEY=your_wallet_private_key_never_commit_this
MNEMONIC=your twelve word mnemonic phrase here for truffle deployments

# ─── Cloud / AWS (optional) ───────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=lendsmart-uploads
